import { NextRequest, NextResponse } from 'next/server';
import { getDataSource } from '../../../../lib/database';
import { Game } from '../../../../entity/Game';
import { checkWinner, getNextPlayer, isValidMove, makeMove, Board, Player } from '../../../../lib/gameLogic';

export async function GET(
  request: NextRequest,
  { params }: { params: { id: string } }
) {
  try {
    const id = parseInt(params.id, 10);
    if (isNaN(id)) {
      return NextResponse.json({ error: 'Invalid game ID' }, { status: 400 });
    }

    const ds = await getDataSource();
    const gameRepo = ds.getRepository(Game);
    const game = await gameRepo.findOne({ where: { id } });

    if (!game) {
      return NextResponse.json({ error: 'Game not found' }, { status: 404 });
    }

    return NextResponse.json(game);
  } catch (error) {
    console.error('Error fetching game:', error);
    return NextResponse.json({ error: 'Failed to fetch game' }, { status: 500 });
  }
}

export async function PUT(
  request: NextRequest,
  { params }: { params: { id: string } }
) {
  try {
    const id = parseInt(params.id, 10);
    if (isNaN(id)) {
      return NextResponse.json({ error: 'Invalid game ID' }, { status: 400 });
    }

    const body = await request.json();
    const { position } = body;

    if (typeof position !== 'number' || position < 0 || position > 8) {
      return NextResponse.json({ error: 'Invalid position. Must be 0-8.' }, { status: 400 });
    }

    const ds = await getDataSource();
    const gameRepo = ds.getRepository(Game);
    const game = await gameRepo.findOne({ where: { id } });

    if (!game) {
      return NextResponse.json({ error: 'Game not found' }, { status: 404 });
    }

    if (game.isComplete) {
      return NextResponse.json({ error: 'Game is already complete' }, { status: 400 });
    }

    const board: Board = JSON.parse(game.board);
    const currentPlayer = game.currentPlayer as Player;

    if (!isValidMove(board, position)) {
      return NextResponse.json({ error: 'Invalid move. Square is already taken.' }, { status: 400 });
    }

    const newBoard = makeMove(board, position, currentPlayer);
    const result = checkWinner(newBoard);

    game.board = JSON.stringify(newBoard);

    if (result.winner) {
      game.winner = result.winner;
      game.isComplete = true;
    } else {
      game.currentPlayer = getNextPlayer(currentPlayer);
    }

    const savedGame = await gameRepo.save(game);
    return NextResponse.json(savedGame);
  } catch (error) {
    console.error('Error updating game:', error);
    return NextResponse.json({ error: 'Failed to update game' }, { status: 500 });
  }
}
