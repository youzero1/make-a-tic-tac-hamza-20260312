'use client';

import React from 'react';

interface GameStatusProps {
  currentPlayer: string;
  winner: string | null;
  isComplete: boolean;
}

export default function GameStatus({ currentPlayer, winner, isComplete }: GameStatusProps) {
  let message: string;
  let bgClass: string;

  if (isComplete) {
    if (winner === 'draw') {
      message = "🤝 It's a Draw!";
      bgClass = 'bg-yellow-500/20 border-yellow-500/30 text-yellow-200';
    } else if (winner) {
      message = `🎉 Player ${winner} Wins!`;
      bgClass = 'bg-green-500/20 border-green-500/30 text-green-200';
    } else {
      message = "🤝 It's a Draw!";
      bgClass = 'bg-yellow-500/20 border-yellow-500/30 text-yellow-200';
    }
  } else {
    const emoji = currentPlayer === 'X' ? '🔵' : '🔴';
    message = `${emoji} Player ${currentPlayer}'s Turn`;
    bgClass = 'bg-white/10 border-white/20 text-white';
  }

  return (
    <div className={`p-3 rounded-xl border text-center font-semibold text-lg ${bgClass}`}>
      {message}
    </div>
  );
}
