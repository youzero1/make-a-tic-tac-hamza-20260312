'O' ? 'text-rose-400' : '';

  return (
    <button
      className={`${baseClasses} ${stateClasses} ${textColor}`}
      onClick={onClick}
      disabled={disabled || value !== ''}
      aria-label={value ? `Square ${value}` : 'Empty square'}
    >
      {value}
    </button>
  );
}
