'use client';

import React from 'react';
import type { GameState } from '@/lib/gameLogic';

interface GameStatusProps {
  gameState: GameState;
}

const GameStatus: React.FC<GameStatusProps> = ({ gameState }) => {
  let message: string;
  let colorClass: string;

  switch (gameState.status) {
    case 'playing':
      message = `Player ${gameState.currentPlayer}'s turn`;
      colorClass = gameState.currentPlayer === 'X' ? 'text-blue-400' : 'text-red-400';
      break;
    case 'won':
      message = `Player ${gameState.winner} wins! 🎉`;
      colorClass = gameState.winner === 'X' ? 'text-blue-400' : 'text-red-400';
      break;
    case 'draw':
      message = "It's a draw! 🤝";
      colorClass = 'text-yellow-400';
      break;
  }

  return (
    <div className="text-center mb-6">
      <p className={`text-xl font-semibold ${colorClass}`}>{message}</p>
    </div>
  );
};

export default GameStatus;
</file>

