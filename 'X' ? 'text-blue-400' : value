'use client';

import React, { useState, useEffect } from 'react';

interface GameRecord {
  id: number;
  board: string;
  currentPlayer: string;
  winner: string | null;
  isComplete: boolean;
  createdAt: string;
  updatedAt: string;
}

export default function GameHistory() {
  const [games, setGames] = useState<GameRecord[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  useEffect(() => {
    let cancelled = false;

    async function fetchGames() {
      try {
        setLoading(true);
        setError(null);
        const res = await fetch('/api/games');
        if (!res.ok) throw new Error('Failed to fetch games');
        const data = await res.json();
        if (!cancelled) {
          setGames(data);
        }
      } catch {
        if (!cancelled) {
          setError('Failed to load game history.');
        }
      } finally {
        if (!cancelled) {
          setLoading(false);
        }
      }
    }

    fetchGames();

    return () => {
      cancelled = true;
    };
  }, []);

  if (loading) {
    return (
      <div className="flex justify-center items-center py-8">
        <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-white"></div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="p-3 bg-red-100/20 text-red-200 rounded-xl text-sm text-center">
        {error}
      </div>
    );
  }

  const completedGames = games.filter((g) => g.isComplete);

  if (completedGames.length === 0) {
    return (
      <div className="text-white/50 text-center py-4 text-sm">
        No completed games yet. Start playing!
      </div>
    );
  }

  return (
    <div className="space-y-2 max-h-96 overflow-y-auto pr-1">
      {completedGames.map((game) => {
        const resultText =
          game.winner === 'draw'
            ? '🤝 Draw'
            : game.winner
            ? `🏆 ${game.winner} Won`
            : 'In Progress';

        const dateStr = new Date(game.createdAt).toLocaleDateString(undefined, {
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });

        return (
          <div
            key={game.id}
            className="flex items-center justify-between p-3 bg-white/5 rounded-xl border border-white/10 text-sm"
          >
            <div className="text-white/80">
              <span className="font-semibold">Game #{game.id}</span>
              <span className="text-white/40 ml-2">{dateStr}</span>
            </div>
            <div className="font-semibold text-white">{resultText}</div>
          </div>
        );
      })}
    </div>
  );
}
